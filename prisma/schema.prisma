generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ListingType {
  JOB_VACANCY
  PROFESSIONAL_PROFILE
}

enum ListingStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum TransactionStatus {
  PENDING
  PAID
  IN_DISPUTE
  RELEASED
  WITHDRAWN
  FAILED
  CANCELED
}

enum MessageType {
  TEXT
  PROPOSAL
  SYSTEM
}

enum SupportTicketStatus {
  ABERTO
  EM_ANALISE
  RESOLVIDO
}

enum BillingType {
  PIX
  CREDIT_CARD
}

model User {
  id                      String         @id @default(cuid())
  nome                    String
  email                   String         @unique
  senha                   String
  cpfCnpj                 String?
  telefone                String?
  cidade                  String?
  uf                      String?
  asaasCustomerId         String?
  asaasWalletId           String?
  curriculoUrl            String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  jobs                    Job[]
  listings                Listing[]
  certificates            Certificate[]
  interests               JobInterest[]
  messagesSent            Message[]
  contractorTransactions  Transaction[]  @relation("ContractorTransactions")
  professionalTransactions Transaction[] @relation("ProfessionalTransactions")
  contractorConversations Conversation[] @relation("ContractorConversations")
  providerConversations   Conversation[] @relation("ProviderConversations")
  supportTickets          SupportTicket[]
}

model Certificate {
  id         String   @id @default(cuid())
  userId     String
  nome       String
  arquivoUrl String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Listing {
  id        String         @id @default(cuid())
  userId    String
  listingType ListingType  @map("tipo")
  titulo    String
  descricao String
  preco     Float?
  aCombinar Boolean        @default(false)
  categoria String
  status    ListingStatus  @default(OPEN)
  cep       String?
  cidade    String
  bairro    String?
  uf        String
  telefone  String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    ListingImage[]
  conversations Conversation[]
  transactions Transaction[]
  supportTickets SupportTicket[]

  @@index([listingType])
  @@index([categoria])
  @@index([cidade, uf])
  @@index([status])
  @@index([createdAt])
  @@index([preco])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  url       String
  ordem     Int     @default(0)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Job {
  id            String         @id @default(cuid())
  titulo        String
  descricao     String
  preco         Float?
  aCombinar     Boolean        @default(false)
  categoria     String
  status        JobStatus      @default(OPEN)
  cep           String?
  cidade        String
  bairro        String?
  uf            String
  telefone      String
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  interests     JobInterest[]
  conversations Conversation[]

  @@index([categoria])
  @@index([cidade, uf])
  @@index([createdAt])
  @@index([status])
}

model JobInterest {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([jobId, userId])
}

model Conversation {
  id           String    @id @default(cuid())
  jobId        String?
  listingId    String?
  contractorId String
  providerId   String
  job          Job?      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  listing      Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contractor   User      @relation("ContractorConversations", fields: [contractorId], references: [id], onDelete: Cascade)
  provider     User      @relation("ProviderConversations", fields: [providerId], references: [id], onDelete: Cascade)
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([jobId, providerId])
  @@unique([listingId, contractorId, providerId])
  @@index([listingId])
}

model Transaction {
  id               String            @id @default(cuid())
  listingId        String
  contractorId     String
  professionalId   String
  asaasPaymentId   String?           @unique
  amountGross      Float
  platformFee      Float
  professionalNet  Float
  billingType      BillingType
  status           TransactionStatus @default(PENDING)
  pixQrCodeImage   String?
  pixCopyPaste     String?
  invoiceUrl       String?
  paymentLink      String?
  dueDate          DateTime?
  paidAt           DateTime?
  contractorConfirmedAt DateTime?
  professionalConfirmedAt DateTime?
  releasedAt       DateTime?
  withdrawnAt      DateTime?
  withdrawPixKey   String?
  withdrawTransferId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  listing          Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contractor       User              @relation("ContractorTransactions", fields: [contractorId], references: [id], onDelete: Cascade)
  professional     User              @relation("ProfessionalTransactions", fields: [professionalId], references: [id], onDelete: Cascade)
  messages         Message[]
  supportTickets   SupportTicket[]

  @@index([listingId])
  @@index([contractorId])
  @@index([professionalId])
  @@index([status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType   @default(TEXT)
  proposalValue  Float?
  transactionId  String?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([transactionId])
}

model SupportTicket {
  id            String             @id @default(cuid())
  transactionId String?
  conversationId String?
  reporterId    String
  descricao     String
  comprovanteUrl String?
  status        SupportTicketStatus @default(ABERTO)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  transaction   Transaction?       @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  reporter      User               @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  @@index([transactionId])
  @@index([reporterId])
  @@index([status])
}
